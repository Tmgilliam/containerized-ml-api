# Containerized ML API — environment template
# Copy to .env for local development. Never commit secrets.

ENVIRONMENT=development
MODEL_PATH=model/model.pkl
MODEL_VERSION=1.0.0

# GCP (deploy pipeline)
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
ARTIFACT_REGISTRY=your-project-id/ml-api
CLOUD_RUN_SERVICE=containerized-ml-api

# Secret Manager secret names (referenced in Terraform)
SECRET_MODEL_VERSION=projects/PROJECT_ID/secrets/model-version/versions/latest
